#!/bin/sh
#
# pre-commit hook: Sync portal mirror files declared in docs/PORTAL_MAP.yaml.
# Runs on every git commit, regardless of which agent or human commits.
#
# Activate with: git config core.hooksPath .githooks
#
# Sync behavior:
#   - only mirror entries declared in docs/PORTAL_MAP.yaml are synced
#   - only staged source files are considered
#   - the same helper is used by sawmill/run.sh for runtime mirror repair

REPO_ROOT=$(git rev-parse --show-toplevel)
CHANGED=0

# Get list of staged files
STAGED=$(git diff --cached --name-only --diff-filter=ACM)
SYNC_HELPER="$REPO_ROOT/sawmill/sync_portal_mirrors.py"

if [ -n "$STAGED" ]; then
    CHANGED_MIRRORS=$(
        python3 "$SYNC_HELPER" --repo-root "$REPO_ROOT" --sources $STAGED
    ) || exit 1

    if [ -n "$CHANGED_MIRRORS" ]; then
        printf '%s\n' "$CHANGED_MIRRORS" | while IFS= read -r path; do
            [ -n "$path" ] || continue
            git add "$REPO_ROOT/$path"
        done
        CHANGED=1
    fi
fi

if [ "$CHANGED" -eq 1 ]; then
    echo "pre-commit: synced source files to docs/ for TechDocs"
fi

# Always allow the commit to proceed
exit 0
